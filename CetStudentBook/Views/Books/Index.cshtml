@model IEnumerable<CetStudentBook.Models.Book>

<h2>Books List</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Book</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Book Name</th>
            <th>Author</th>
            <th>Publish Date</th>
            <th>Page Count</th>
            <th>Second Hand</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Author</td>
                <td>@item.PublishDate.ToShortDateString()</td>
                <td>@item.PageCount</td>
                <td>@(item.IsSecondHand)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>